@OptIn(ExperimentalMaterial3Api::class)
@Composable
fun AddItemEntryScreen(
    categories: List<Any> = emptyList(),
    onNavigateBack: () -> Unit,
    onNavigateToCategory: (Long) -> Unit,
    onNavigateToCustom: () -> Unit,
    onQuickAdd: (String) -> Unit
) {
    Scaffold(
        topBar = {
            TopAppBar(
                title = {
                    Text(
                        "添加提醒",
                        style = MaterialTheme.typography.titleLarge,
                        fontWeight = FontWeight.Bold
                    )
                },
                navigationIcon = {
                    IconButton(onClick = onNavigateBack) {
                        Icon(Icons.Default.Close, contentDescription = "关闭")
                    }
                }
            )
        },
        containerColor = Color.White
    ) { padding ->
        Column(
            modifier = Modifier
                .fillMaxSize()
                .padding(padding)
                .padding(horizontal = 16.dp)
        ) {
            SearchBar(
                modifier = Modifier.fillMaxWidth(),
                placeholder = { Text("搜索物品/事项，如：牛奶、身份证、车险", color = Color(0xFFBDBDBD), fontSize = 14.sp) },
                query = "",
                onQueryChange = {},
                onSearch = {},
                active = false,
                onActiveChange = {},
                leadingIcon = {
                    Icon(Icons.Default.Search, contentDescription = null, tint = Color(0xFF86909C))
                },
                shape = RoundedCornerShape(24.dp),
                colors = SearchBarDefaults.colors(
                    containerColor = Color(0xFFF5F5F5)
                )
            ) {}

            Spacer(modifier = Modifier.height(24.dp))

            Text(
                "常用快捷添加",
                fontSize = 16.sp,
                fontWeight = FontWeight.Bold,
                color = Color(0xFF333333)
            )

            Spacer(modifier = Modifier.height(12.dp))

            val quickCategories = listOf(
                Triple("牛奶", "🥛", Color(0xFF4FC3F7)),
                Triple("药品", "💊", Color(0xFFFF6B6B)),
                Triple("身份证", "🆔", Color(0xFF4ECDC4)),
                Triple("车险", "🚗", Color(0xFF45B7D1)),
                Triple("会员", "⭐", Color(0xFFFFA726)),
                Triple("护肤品", "🧴", Color(0xFFE056FD)),
                Triple("牙刷", "🪥", Color(0xFF26C6DA)),
                Triple("灭火器", "🧯", Color(0xFFEF5350)),
                Triple("会员", "🎫", Color(0xFFAB47BC)),
                Triple("更多", "⋯", Color(0xFF95A5A6))
            )

            LazyVerticalGrid(
                columns = GridCells.Fixed(5),
                horizontalArrangement = Arrangement.spacedBy(12.dp),
                verticalArrangement = Arrangement.spacedBy(12.dp),
                modifier = Modifier.height(160.dp)
            ) {
                items(quickCategories) { (name, emoji, color) ->
                    Column(
                        modifier = Modifier
                            .clickable { if (name != "更多") onQuickAdd(name) },
                        horizontalAlignment = Alignment.CenterHorizontally
                    ) {
                        Box(
                            modifier = Modifier
                                .size(48.dp)
                                .clip(RoundedCornerShape(12.dp))
                                .background(color.copy(alpha = 0.15f))
                                .padding(10.dp),
                            contentAlignment = Alignment.Center
                        ) {
                            Text(emoji, fontSize = 24.sp)
                        }
                        Spacer(modifier = Modifier.height(4.dp))
                        Text(name, fontSize = 11.sp, color = Color(0xFF333333), fontWeight = FontWeight.Medium)
                    }
                }
            }

            Spacer(modifier = Modifier.height(24.dp))

            Text(
                "选择分类",
                fontSize = 16.sp,
                fontWeight = FontWeight.Bold,
                color = Color(0xFF333333)
            )

            Spacer(modifier = Modifier.height(12.dp))

            LazyVerticalGrid(
                columns = GridCells.Fixed(2),
                horizontalArrangement = Arrangement.spacedBy(12.dp),
                verticalArrangement = Arrangement.spacedBy(12.dp)
            ) {
                items(mainCategoriesList) { category ->
                    CategoryGridItemNew(
                        category = category,
                        onClick = { onNavigateToCategory(category.id) }
                    )
                }
            }

            Spacer(modifier = Modifier.height(16.dp))

            Box(
                modifier = Modifier
                    .fillMaxWidth()
                    .clip(RoundedCornerShape(12.dp))
                    .background(Color(0xFFF8F9FA))
                    .clickable { onNavigateToCustom() }
                    .padding(vertical = 14.dp),
                contentAlignment = Alignment.Center
            ) {
                Row(
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    Icon(Icons.Default.Add, contentDescription = null, tint = Color(0xFF5FCF80), modifier = Modifier.size(18.dp))
                    Spacer(modifier = Modifier.width(6.dp))
                    Text("自定义物品/事项", fontSize = 14.sp, color = Color(0xFF5FCF80), fontWeight = FontWeight.Medium)
                }
            }

            Spacer(modifier = Modifier.height(32.dp))
        }
    }
}

@Composable
fun CategoryGridItemNew(
    category: MainCategory,
    onClick: () -> Unit
) {
    Card(
        modifier = Modifier
            .fillMaxWidth()
            .clickable(onClick = onClick),
        shape = RoundedCornerShape(12.dp),
        colors = CardDefaults.cardColors(containerColor = category.bgColor),
        elevation = CardDefaults.cardElevation(defaultElevation = 0.dp)
    ) {
        Row(
            modifier = Modifier.padding(12.dp),
            verticalAlignment = Alignment.CenterVertically
        ) {
            Icon(
                category.icon,
                contentDescription = null,
                tint = category.iconColor,
                modifier = Modifier.size(24.dp)
            )
            
            Spacer(modifier = Modifier.width(10.dp))
            
            Column(modifier = Modifier.weight(1f)) {
                Text(
                    text = category.name,
                    fontSize = 13.sp,
                    fontWeight = FontWeight.Medium,
                    color = Color(0xFF333333),
                    maxLines = 1
                )
                Text(
                    text = category.description,
                    fontSize = 11.sp,
                    color = Color(0xFF86909C),
                    maxLines = 1
                )
            }
            
            Icon(
                Icons.Default.ChevronRight,
                contentDescription = null,
                tint = Color(0xFFC7C7CC),
                modifier = Modifier.size(20.dp)
            )
        }
    }
}
