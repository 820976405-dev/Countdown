data class MainCategory(
    val id: Long,
    val name: String,
    val icon: ImageVector,
    val iconColor: Color,
    val bgColor: Color,
    val description: String,
    val subCategories: List<SubCategory>
)

data class SubCategory(
    val id: Long,
    val name: String,
    val items: List<TemplateItem>
)

data class TemplateItem(
    val id: Long,
    val name: String,
    val iconEmoji: String,
    val description: String = ""
)

